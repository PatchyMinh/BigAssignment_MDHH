<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.HomeController">
    <content>
        <VBox spacing="25.0" style="-fx-background-color: #f8f9fa;">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="20.0" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <Label text="🔨 Đấu Giá Trực Tuyến" textFill="#1a73e8" HBox.hgrow="ALWAYS">
                    <font><Font name="System Bold" size="24.0" /></font>
                </Label>
                <HBox alignment="CENTER_RIGHT" spacing="15.0" HBox.hgrow="ALWAYS">
                    <Button onAction="#handleCreateSession" style="-fx-background-color: transparent; -fx-cursor: hand;" text="+ Tạo phiên">
                        <font><Font size="14.0" /></font>
                    </Button>
                    <Button onAction="#handleProfile" style="-fx-background-color: transparent; -fx-cursor: hand;" text="👤 Tài khoản">
                        <font><Font size="14.0" /></font>
                    </Button>
                </HBox>
            </HBox>

            <Label text="Danh Sách Sản Phẩm Đấu Giá">
                <font><Font name="System Bold" size="20.0" /></font>
            </Label>

            <TextField fx:id="txtSearch" prefHeight="45.0" promptText="🔍 Tìm kiếm sản phẩm..." style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 8; -fx-background-radius: 8;">
                <font><Font size="14.0" /></font>
            </TextField>

            <HBox spacing="10.0">
                <Button mnemonicParsing="false" onAction="#filterAll" prefHeight="35.0" style="-fx-background-color: #1a73e8; -fx-background-radius: 5; -fx-cursor: hand;" text="Tất cả" textFill="WHITE">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Button mnemonicParsing="false" onAction="#filterElectronics" prefHeight="35.0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 5; -fx-cursor: hand;" text="Đồ điện tử" textFill="#333333" />
                <Button mnemonicParsing="false" onAction="#filterVehicles" prefHeight="35.0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 5; -fx-cursor: hand;" text="Xe cộ" textFill="#333333" />
                <Button mnemonicParsing="false" onAction="#filterArts" prefHeight="35.0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 5; -fx-cursor: hand;" text="Tranh nghệ thuật" textFill="#333333" />
            </HBox>

            <FlowPane fx:id="productContainer" hgap="25.0" vgap="25.0" />

        </VBox>
    </content>
</ScrollPane>